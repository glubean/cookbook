# Secrets — copy this file to .env.secrets (gitignored).
#
# The default .env already has working non-secret values, so smoke tests
# (explore/dummyjson, explore/github/smoke) run immediately without this file.
#
# You only need .env.secrets for recipes that require authentication.

# GitHub token — required for explore/github/advanced
# Get one at: https://github.com/settings/tokens (scopes: read:user, public_repo)
GITHUB_TOKEN=ghp_...

# Stripe — required for explore/stripe
# Use your test mode secret key (never your live key): sk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Smee.io tunnel — required for explore/stripe/webhook
# 1. Go to https://smee.io/new
# 2. Copy the channel URL and paste it here
SMEE_URL=https://smee.io/your-channel
